WARRANTY_COVERAGE_CAP_USDC=0.50
WARRANTY_MAX_TARGET_PRICE_USDC=0.10
WARRANTY_MIN_TIMEOUT_SECONDS=600
WARRANTY_TARGET_TIMEOUT_SECONDS=600
WARRANTY_MAX_TIMEOUT_SECONDS=3600
WARRANTY_TARGET_ACCEPT_SECONDS=180
WARRANTY_BUYER_TIMEOUT_SECONDS=480
WARRANTY_CROO_READ_TIMEOUT_SECONDS=30
WARRANTY_CROO_WRITE_TIMEOUT_SECONDS=120
WARRANTY_HEALTH_MAX_AGE_SECONDS=90
WARRANTY_MAX_ORDERS_PER_BUYER_WINDOW=1
WARRANTY_BUYER_WINDOW_SECONDS=86400
WARRANTY_REFUND_DRY_RUN=1
